# ===================================================================
# 警告：所有 PUBLIC_ 開頭的變數會被打包進前端 bundle，等同公開資訊
#       LINE Channel Access Token / Secret、API key 一律不可放這裡
# ===================================================================

# Sanity（客戶 Gmail 開戶後填入）
PUBLIC_SANITY_PROJECT_ID=your_project_id
PUBLIC_SANITY_DATASET=production
PUBLIC_SANITY_API_VERSION=2025-01-01

# Formspree（客戶 Gmail 開戶後填入）
PUBLIC_FORMSPREE_FORM_ID=your_form_id

# LINE 加好友連結維護方式：直接編輯 src/lib/site.ts 的 lineAddFriendUrl
# 用 lin.ee 短網址（從 LINE OA 後台「加入好友指南」取得，避免 @ 編碼問題）

# GA4 / GTM
PUBLIC_GTM_ID=GTM-XXXXXXX
