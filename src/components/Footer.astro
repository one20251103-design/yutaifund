---
import { SITE } from '~/lib/site';

const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-gold-200)]/40 mt-32 py-16 bg-[var(--color-cream-50)]">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
      <div>
        <div class="mb-4">
          <p class="text-lg font-medium tracking-wider text-[var(--color-ink-900)]">
            {SITE.name}
          </p>
          <p class="text-xs tracking-[0.3em] text-[var(--color-gold-500)] font-display mt-1">
            {SITE.englishName}
          </p>
        </div>
        <p class="text-sm text-[var(--color-ink-500)] leading-relaxed">
          {SITE.slogan}
        </p>
      </div>

      <div>
        <p class="text-sm font-medium text-[var(--color-ink-900)] mb-4 tracking-[0.15em]">
          聯絡資訊
        </p>
        <ul class="space-y-2.5 text-sm text-[var(--color-ink-500)]">
          <li>
            <a
              href={`tel:${SITE.phone}`}
              class="hover:text-[var(--color-gold-500)] transition-colors"
            >
              {SITE.phone}
            </a>
          </li>
          <li>
            <a
              href={`mailto:${SITE.email}`}
              class="hover:text-[var(--color-gold-500)] transition-colors"
            >
              {SITE.email}
            </a>
          </li>
          <li>{SITE.address}</li>
        </ul>
      </div>

      <div>
        <p class="text-sm font-medium text-[var(--color-ink-900)] mb-4 tracking-[0.15em]">
          即時聯繫
        </p>
        <a
          href={SITE.lineAddFriendUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-2.5 bg-[var(--color-gold-400)] hover:bg-[var(--color-gold-500)] text-white text-sm rounded-full tracking-wider transition-colors"
        >
          加入 LINE 諮詢
        </a>
      </div>
    </div>

    <div class="pt-8 border-t border-[var(--color-gold-200)]/30 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-[var(--color-ink-500)]">
      <p>© {year} {SITE.fullName}</p>
      <div class="flex gap-6">
        <a
          href="/privacy"
          class="hover:text-[var(--color-gold-500)] transition-colors"
        >
          隱私權政策
        </a>
        <a
          href="/terms"
          class="hover:text-[var(--color-gold-500)] transition-colors"
        >
          使用條款
        </a>
      </div>
    </div>
  </div>
</footer>
