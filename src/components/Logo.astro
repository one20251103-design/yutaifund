---
interface Props {
  className?: string;
  height?: number;
}

// 預設高度 88px，多層 drop-shadow 製造立體感讓 logo 自身對比足夠（不靠背景 chip）
const { className = '', height = 88 } = Astro.props;
---

<img
  src="/yutaifund-logo.png"
  alt="鈺泰發行銷有限公司"
  width={Math.round(height * 0.85)}
  height={height}
  class:list={['w-auto object-contain logo-img', className]}
  style={`max-height: ${height}px;`}
  loading="eager"
  decoding="async"
/>

<style>
  /*
    LOGO 對比強化：
    原 PNG 整體為淺香檳金（Y + 中英文都是 #E8DCBA 級的淺色），放在淺底會糊。
    用 brightness 0.55 + saturate 1.6 + contrast 1.5 把整個 logo 壓深成鎏金 / 古銅金色，
    保留金色色相但提升明度差異，文字段就會清楚顯現。再疊多層 drop-shadow 增加立體感。
  */
  .logo-img {
    filter:
      brightness(0.55)
      saturate(1.6)
      contrast(1.5)
      drop-shadow(0 1px 1px rgba(0, 0, 0, 0.20))
      drop-shadow(0 2px 6px rgba(0, 0, 0, 0.14));
  }
</style>
