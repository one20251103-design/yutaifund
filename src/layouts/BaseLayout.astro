---
import { ClientRouter } from 'astro:transitions';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import SpotlightCursor from '~/components/SpotlightCursor.tsx';
import SpeedDial from '~/components/SpeedDial.tsx';
import DesignPanel from '~/components/DesignPanel.tsx';
import CookieConsent from '~/components/CookieConsent.tsx';
import StructuredData from '~/components/StructuredData.astro';
import { SITE } from '~/lib/site';
import '~/styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
  breadcrumbs?: Array<{ name: string; href: string }>;
  article?: {
    title: string;
    description: string;
    datePublished: string;
    image: string;
  };
  listing?: {
    name: string;
    description: string;
    image: string;
    location?: string;
    propertyType?: string;
  };
}

const {
  title,
  description = SITE.description,
  ogImage = 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=1200&q=80',
  noIndex = false,
  breadcrumbs,
  article,
  listing,
} = Astro.props;

const fullTitle = title ? `${title}｜${SITE.name}` : `${SITE.name}｜${SITE.slogan}`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const gtmId = import.meta.env.PUBLIC_GTM_ID;

// 設計色票切換器：上線可由 PUBLIC_DESIGN_PANEL=false 關閉
const designPanelEnabled = (import.meta.env.PUBLIC_DESIGN_PANEL ?? 'true') !== 'false';
---

<!doctype html>
<html lang="zh-Hant-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#C8A765" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:locale" content="zh_TW" />
    <meta property="og:site_name" content={SITE.name} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />

    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Noto+Sans+TC:wght@300;400;500;700&display=swap"
    />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <StructuredData breadcrumbs={breadcrumbs} article={article} listing={listing} />

    {/* 預設 data-theme：avoid theme flash，必須在 body 渲染前執行 */}
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('yutaifund-theme');
          var ok = ['warm-cream', 'cool-navy', 'sage-japandi', 'mist-violet'];
          if (t && ok.indexOf(t) !== -1) {
            document.documentElement.setAttribute('data-theme', t);
          }
        } catch (e) {}
      })();
    </script>

    <ClientRouter />

    {gtmId && (
      <script is:inline define:vars={{ gtmId }}>
        (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer',gtmId);
      </script>
    )}
  </head>
  <body>
    <Header />

    <main id="main">
      <slot />
    </main>

    <Footer />

    <SpotlightCursor client:load />
    <SpeedDial client:load />
    {designPanelEnabled && <DesignPanel client:load />}
    <CookieConsent client:idle />

    <!-- Reveal IntersectionObserver：觸發 .reveal → .is-visible 慢速淡入 -->
    <script>
      const setupReveal = () => {
        const reveals = document.querySelectorAll<HTMLElement>('.reveal:not(.is-visible)');
        if (!reveals.length) return;

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.05, rootMargin: '0px 0px -60px 0px' }
        );

        reveals.forEach((el) => observer.observe(el));
      };

      document.addEventListener('astro:page-load', setupReveal);
      // 也在初次直接 load 時跑一次（防止 page-load 沒觸發）
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', setupReveal);
      } else {
        setupReveal();
      }
    </script>

    {gtmId && (
      <noscript>
        <iframe
          src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
          height="0"
          width="0"
          style="display:none;visibility:hidden"
          title="GTM"
        ></iframe>
      </noscript>
    )}
  </body>
</html>
