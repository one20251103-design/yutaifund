---
import BaseLayout from '~/layouts/BaseLayout.astro';
import NavIcon from '~/components/NavIcon.astro';
import { NAV_ITEMS } from '~/lib/site';

const aboutNav = NAV_ITEMS.find((item) => item.href === '/about');
const aboutSubpages = aboutNav?.children ?? [];

const ABOUT_HERO =
  'https://images.unsplash.com/photo-1497366216548-37526070297c?w=1600&q=80&auto=format&fit=crop';
---

<BaseLayout
  title="關於我們"
  description="鈺泰發行銷有限公司，深耕宜蘭房地產市場，專業提供新成屋代銷與中古屋買賣服務，以「安心」為核心理念。"
  breadcrumbs={[
    { name: '首頁', href: '/' },
    { name: '關於我們', href: '/about' },
  ]}
>
  <!-- Hero -->
  <section class="pt-32 pb-16">
    <div class="container-custom">
      <p class="text-xs tracking-[0.4em] text-[var(--color-gold-500)] font-display mb-6">
        ABOUT US
      </p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-light tracking-wide leading-tight text-[var(--color-ink-900)] mb-8 max-w-4xl">
        以「安心」為核心<br />重新定義房地產代銷
      </h1>
      <p class="text-base md:text-lg text-[var(--color-ink-500)] max-w-2xl leading-relaxed">
        鈺泰發行銷源自對「住得安心」的堅持。我們相信每一個家的選擇都值得被慎重對待，從建商口碑、物件品質到合約細節，皆以買家立場為優先考量。
      </p>
    </div>
  </section>

  <!-- Hero 圖 -->
  <section class="pb-16 lg:pb-20">
    <div class="container-custom">
      <div class="aspect-[21/9] overflow-hidden">
        <img
          src={ABOUT_HERO}
          alt="專業諮詢場景"
          class="w-full h-full object-cover"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- 6 個子頁卡片導覽 -->
  <section class="pb-20 lg:pb-28">
    <div class="container-custom">
      <p class="text-xs tracking-[0.3em] text-[var(--color-gold-500)] font-display mb-4">
        EXPLORE
      </p>
      <h2 class="text-2xl md:text-3xl font-light tracking-wide text-[var(--color-ink-900)] mb-12">
        深入了解鈺泰發
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {aboutSubpages.map((page, i) => (
          <a
            href={page.href}
            class="group flex flex-col bg-white border border-[var(--color-gold-200)]/40 p-7 hover:border-[var(--color-gold-400)] hover:shadow-md transition-all duration-300"
          >
            <div class="flex items-start justify-between mb-6">
              {page.icon && (
                <span class="w-12 h-12 flex items-center justify-center rounded-md bg-[var(--color-cream-100)] group-hover:bg-[var(--color-gold-100)] text-[var(--color-gold-600)] transition-colors">
                  <NavIcon name={page.icon} class="w-6 h-6" />
                </span>
              )}
              <p class="text-xs tracking-[0.3em] text-[var(--color-gold-500)] font-display">
                {String(i + 1).padStart(2, '0')}
              </p>
            </div>
            <h3 class="text-xl font-light text-[var(--color-ink-900)] mb-3 tracking-wider group-hover:text-[var(--color-gold-600)] transition-colors">
              {page.label}
            </h3>
            <p class="text-sm text-[var(--color-ink-500)] leading-relaxed mb-6 flex-1">
              {page.description}
            </p>
            <span class="inline-flex items-center gap-2 text-sm tracking-widest text-[var(--color-gold-600)] group-hover:text-[var(--color-gold-700)]">
              了解更多
              <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 bg-[var(--color-cream-50)] border-t border-[var(--color-gold-200)]/30">
    <div class="container-custom max-w-3xl text-center">
      <h2 class="text-2xl md:text-3xl font-light tracking-wide text-[var(--color-ink-900)] mb-6">
        想了解我們的服務細節？
      </h2>
      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href="/portfolio"
          class="inline-flex items-center gap-2 px-7 py-3.5 bg-[var(--color-gold-400)] hover:bg-[var(--color-gold-500)] text-white text-sm tracking-wider rounded-full transition-colors"
        >
          瀏覽精選建案
        </a>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 px-7 py-3.5 border border-[var(--color-gold-300)] text-[var(--color-ink-700)] hover:bg-white text-sm tracking-wider rounded-full transition-colors"
        >
          聯絡我們
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
