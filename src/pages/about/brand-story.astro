---
import SubpageLayout from '~/layouts/SubpageLayout.astro';

const VALUES = [
  { num: '01', title: '鈺泰用心', desc: '從物件盤點到客戶服務，每一個環節皆以專業與細心對待。我們重視「品質」遠勝「速度」。' },
  { num: '02', title: '購屋安心', desc: '透明資訊、合理估價、誠實揭露，讓每位買家都能基於完整資訊做決定，不被資訊不對稱影響權益。' },
  { num: '03', title: '建商放心', desc: '專業代銷團隊維護建商品牌口碑，協助建商精準觸達合適買家，避免低品質媒合造成的信任損失。' },
];
---

<SubpageLayout
  title="品牌故事"
  description="鈺泰發行銷源自對「住得安心」的堅持。我們相信每一個家的選擇都值得被慎重對待。"
  parentHref="/about"
  eyebrow="BRAND STORY"
  heroImage="https://images.unsplash.com/photo-1497366216548-37526070297c?w=1600&q=80&auto=format&fit=crop"
  heroImageAlt="鈺泰發品牌形象"
  breadcrumbs={[
    { name: '首頁', href: '/' },
    { name: '關於我們', href: '/about' },
    { name: '品牌故事', href: '/about/brand-story' },
  ]}
>
  <!-- 創立理念 -->
  <section class="py-16 lg:py-20">
    <div class="container-custom max-w-4xl">
      <p class="text-xs tracking-[0.3em] text-[var(--color-gold-500)] font-display mb-4">
        OUR ORIGIN
      </p>
      <h2 class="text-2xl md:text-3xl font-light tracking-wide text-[var(--color-ink-900)] mb-8">
        從一個簡單的信念開始
      </h2>
      <div class="space-y-6 text-base text-[var(--color-ink-500)] leading-relaxed">
        <p>
          房地產交易牽涉一個家庭數十年的積蓄與生活軌跡，這不是一場單純的買賣，而是一份長期的承諾。
        </p>
        <p>
          鈺泰發行銷由具備房地產實務經驗的團隊成立，深耕宜蘭在地市場。我們深信，地段不只是經緯度——每一條巷弄的氣味、每一個社區的鄰里結構、每一片山景的季節變化，都會影響買家未來十年的居住體驗。
        </p>
        <p>
          我們的差異化在於「細節品質」：每一個物件皆經過實地勘查、合理估價與透明揭露；每一份合約皆逐條解讀；每一次交付皆協助驗收。這不是理所當然，而是我們選擇做的事。
        </p>
      </div>
    </div>
  </section>

  <!-- 三方共贏 -->
  <section class="py-16 lg:py-20 bg-[var(--color-cream-50)]">
    <div class="container-custom">
      <div class="max-w-2xl mb-16">
        <p class="text-xs tracking-[0.3em] text-[var(--color-gold-500)] font-display mb-4">
          OUR PHILOSOPHY
        </p>
        <h2 class="text-2xl md:text-3xl font-light tracking-wide text-[var(--color-ink-900)] mb-6">
          三方共贏的核心理念
        </h2>
        <p class="text-base text-[var(--color-ink-500)] leading-relaxed">
          房地產交易是一場長期的合作關係，唯有買家、屋主、建商三方都安心，才是好的成交。
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        {VALUES.map((item) => (
          <div>
            <p class="text-xs tracking-[0.3em] text-[var(--color-gold-500)] font-display mb-4">
              {item.num}
            </p>
            <h3 class="text-2xl font-light text-[var(--color-ink-900)] mb-4 tracking-wider">
              {item.title}
            </h3>
            <p class="text-sm text-[var(--color-ink-500)] leading-relaxed">
              {item.desc}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 經典案例（placeholder） -->
  <section class="py-16 lg:py-20">
    <div class="container-custom">
      <p class="text-xs tracking-[0.3em] text-[var(--color-gold-500)] font-display mb-4">
        CASE STUDIES
      </p>
      <h2 class="text-2xl md:text-3xl font-light tracking-wide text-[var(--color-ink-900)] mb-10">
        經典代銷案例
      </h2>

      <div class="border border-dashed border-[var(--color-gold-300)]/60 bg-[var(--color-cream-50)]/40 p-12 text-center">
        <p class="text-xs tracking-[0.3em] text-[var(--color-gold-500)] font-display mb-4">
          待業主提供
        </p>
        <p class="text-base text-[var(--color-ink-700)] leading-relaxed mb-2">
          代表性代銷案例整理中
        </p>
        <p class="text-sm text-[var(--color-ink-500)]/80 leading-relaxed max-w-xl mx-auto">
          敬請鈺泰發提供：1–3 個代表性代銷實績的故事（建案名、合作背景、銷售成果、客戶回饋）。
        </p>
      </div>
    </div>
  </section>
</SubpageLayout>
