---
import SubpageLayout from '~/layouts/SubpageLayout.astro';
import { getCsrActivitiesList } from '~/lib/content';

const activities = await getCsrActivitiesList();
---

<SubpageLayout
  title="社會公益"
  description="從在地出發、回饋鄉里。鈺泰發行銷持續以實際行動參與宜蘭在地的公益活動。"
  parentHref="/about"
  eyebrow="CSR"
  breadcrumbs={[
    { name: '首頁', href: '/' },
    { name: '關於我們', href: '/about' },
    { name: '社會公益', href: '/about/csr' },
  ]}
>
  <!-- 公益理念 -->
  <section class="py-16 lg:py-20">
    <div class="container-custom max-w-3xl">
      <p class="text-xs tracking-[0.3em] text-[var(--color-gold-500)] font-display mb-4">
        OUR COMMITMENT
      </p>
      <h2 class="text-2xl md:text-3xl font-light tracking-wide text-[var(--color-ink-900)] mb-8">
        從在地出發、回饋鄉里
      </h2>
      <div class="space-y-6 text-base text-[var(--color-ink-500)] leading-relaxed">
        <p>
          一間紮根在地的企業，最深的責任不是繳稅，而是讓周遭社區因為我們的存在而變得更好一些。
        </p>
        <p>
          鈺泰發行銷將每一年的部分盈餘投入在地公益，從社區關懷、教育贊助到弱勢家庭購屋諮詢，我們相信這些行動會在十年、二十年後形成一個更好的宜蘭。
        </p>
      </div>
    </div>
  </section>

  <!-- 公益活動清單 -->
  <section class="py-16 lg:py-20 bg-[var(--color-cream-50)]">
    <div class="container-custom">
      <p class="text-xs tracking-[0.3em] text-[var(--color-gold-500)] font-display mb-4">
        CSR ACTIVITIES
      </p>
      <h2 class="text-2xl md:text-3xl font-light tracking-wide text-[var(--color-ink-900)] mb-12">
        公益活動紀錄
      </h2>

      {activities.length === 0 ? (
        <div class="border border-dashed border-[var(--color-gold-300)]/60 bg-white p-12 text-center">
          <p class="text-xs tracking-[0.3em] text-[var(--color-gold-500)] font-display mb-4">
            待業主提供
          </p>
          <p class="text-base text-[var(--color-ink-700)] leading-relaxed mb-2">
            公益活動紀錄整備中
          </p>
          <p class="text-sm text-[var(--color-ink-500)]/80 leading-relaxed max-w-xl mx-auto">
            請至 Sanity Studio 後台「❤️ 社會公益」新增活動：名稱、類別、年份、說明、合作單位、活動照片。
          </p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {activities.map((item) => (
            <div class="bg-white border border-[var(--color-gold-200)]/40 overflow-hidden flex flex-col">
              {item.photo && (
                <div class="aspect-[4/3] overflow-hidden">
                  <img src={item.photo} alt={item.title} class="w-full h-full object-cover" loading="lazy" />
                </div>
              )}
              <div class="p-7 flex-1 flex flex-col">
                <p class="text-xs tracking-[0.3em] text-[var(--color-gold-500)] font-display mb-2">
                  {item.category}
                </p>
                <p class="text-xs text-[var(--color-ink-500)] tracking-wider mb-3">
                  {item.year}
                  {item.partnerOrg && ` · 合作：${item.partnerOrg}`}
                </p>
                <h3 class="text-lg font-light text-[var(--color-ink-900)] mb-3 tracking-wider">
                  {item.title}
                </h3>
                <p class="text-sm text-[var(--color-ink-500)] leading-relaxed flex-1">
                  {item.description}
                </p>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- 邀請參與 -->
  <section class="py-16 lg:py-20">
    <div class="container-custom max-w-3xl text-center">
      <p class="text-xs tracking-[0.3em] text-[var(--color-gold-500)] font-display mb-4">
        JOIN US
      </p>
      <h2 class="text-2xl md:text-3xl font-light tracking-wide text-[var(--color-ink-900)] mb-6">
        歡迎與我們一起讓宜蘭更好
      </h2>
      <p class="text-sm text-[var(--color-ink-500)] mb-8 leading-relaxed">
        如果您有想合作的在地公益專案，或希望我們贊助的活動，歡迎透過 LINE 或服務專線與我們聯繫。
      </p>
      <a
        href="/contact"
        class="inline-flex items-center gap-2 px-7 py-3.5 bg-[var(--color-gold-400)] hover:bg-[var(--color-gold-500)] text-white text-sm tracking-wider rounded-full transition-colors"
      >
        聯絡我們
      </a>
    </div>
  </section>
</SubpageLayout>
