---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { SITE } from '~/lib/site';

const RENTAL_TYPES = [
  { type: '套房', range: '6,000 ~ 15,000 / 月', area: '5 ~ 12 坪' },
  { type: '兩房一廳', range: '12,000 ~ 22,000 / 月', area: '15 ~ 25 坪' },
  { type: '三房一廳', range: '18,000 ~ 35,000 / 月', area: '25 ~ 40 坪' },
  { type: '透天厝', range: '25,000 ~ 60,000 / 月', area: '40 坪以上' },
  { type: '店面 / 商辦', range: '依地段而定', area: '依坪數而定' },
];

const RENTAL_AREAS = ['礁溪', '宜蘭市', '羅東', '五結', '頭城', '冬山', '蘇澳'];
---

<BaseLayout
  title="租屋資訊"
  description="鈺泰發行銷宜蘭在地租屋物件，套房、住家、透天、商辦一應俱全，並透過 JGB Smart 系統提供透明化租賃管理。"
  breadcrumbs={[
    { name: '首頁', href: '/' },
    { name: '仲介服務', href: '/agency' },
    { name: '租屋資訊', href: '/agency/rental' },
  ]}
>
  <section class="pt-32 pb-12">
    <div class="container-custom">
      <p class="text-xs tracking-[0.4em] text-[var(--color-gold-500)] font-display mb-6">
        RENTAL
      </p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-light tracking-wide leading-tight text-[var(--color-ink-900)] mb-8">
        宜蘭在地租屋資訊
      </h1>
      <p class="text-base md:text-lg text-[var(--color-ink-500)] max-w-2xl leading-relaxed">
        從套房到透天、從住家到商辦，鈺泰發整合宜蘭縣全區租賃物件，並透過 JGB Smart 智能租賃系統提供透明化的租約、租金與修繕管理。
      </p>
    </div>
  </section>

  <!-- 物件型態 -->
  <section class="pb-16 lg:pb-24">
    <div class="container-custom">
      <p class="text-xs tracking-[0.3em] text-[var(--color-gold-500)] font-display mb-4">
        PROPERTY TYPES
      </p>
      <h2 class="text-2xl md:text-3xl font-light tracking-wide text-[var(--color-ink-900)] mb-10">
        物件型態與行情參考
      </h2>

      <div class="border border-[var(--color-gold-200)]/40 bg-white overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-[var(--color-cream-50)] text-[var(--color-ink-700)] tracking-widest">
            <tr>
              <th class="px-6 py-4 text-left font-medium">物件型態</th>
              <th class="px-6 py-4 text-left font-medium">月租範圍</th>
              <th class="px-6 py-4 text-left font-medium">坪數範圍</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-[var(--color-gold-200)]/30 text-[var(--color-ink-700)]">
            {RENTAL_TYPES.map((item) => (
              <tr class="hover:bg-[var(--color-cream-50)]/60">
                <td class="px-6 py-4 font-light">{item.type}</td>
                <td class="px-6 py-4 text-[var(--color-gold-700)] tracking-wider">{item.range}</td>
                <td class="px-6 py-4">{item.area}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="mt-4 text-xs text-[var(--color-ink-500)]/70 tracking-wider">
        ※ 以上為宜蘭市場參考行情，實際物件價格依地段、屋況、屋齡而異。詳細物件清單請洽服務專線。
      </p>
    </div>
  </section>

  <!-- 服務區域 -->
  <section class="pb-16 lg:pb-24 bg-[var(--color-cream-50)] py-16">
    <div class="container-custom">
      <p class="text-xs tracking-[0.3em] text-[var(--color-gold-500)] font-display mb-4">
        SERVICE AREAS
      </p>
      <h2 class="text-2xl md:text-3xl font-light tracking-wide text-[var(--color-ink-900)] mb-10">
        主要服務區域
      </h2>

      <div class="flex flex-wrap gap-3">
        {RENTAL_AREAS.map((area) => (
          <span class="inline-block px-5 py-2.5 bg-white border border-[var(--color-gold-300)]/50 text-sm tracking-wider text-[var(--color-ink-700)]">
            {area}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- 物件清單 placeholder -->
  <section class="pb-16 lg:pb-24">
    <div class="container-custom">
      <p class="text-xs tracking-[0.3em] text-[var(--color-gold-500)] font-display mb-4">
        LISTINGS
      </p>
      <h2 class="text-2xl md:text-3xl font-light tracking-wide text-[var(--color-ink-900)] mb-10">
        最新物件
      </h2>

      <div class="border border-dashed border-[var(--color-gold-300)]/60 bg-[var(--color-cream-50)]/40 p-12 text-center">
        <p class="text-xs tracking-[0.3em] text-[var(--color-gold-500)] font-display mb-4">
          待業主提供 / 系統整合
        </p>
        <p class="text-base text-[var(--color-ink-700)] leading-relaxed mb-2">
          物件清單模組整備中
        </p>
        <p class="text-sm text-[var(--color-ink-500)]/80 leading-relaxed max-w-xl mx-auto">
          將從 JGB Smart 系統 / 自家 CMS 串接物件資料（物件名稱、地址、坪數、月租、押金、設備、實景照片）。請業主確認資料來源。
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-[var(--color-cream-50)] border-t border-[var(--color-gold-200)]/30">
    <div class="container-custom max-w-3xl text-center">
      <h2 class="text-2xl md:text-3xl font-light tracking-wide text-[var(--color-ink-900)] mb-6">
        想找房？想出租物件？
      </h2>
      <p class="text-sm text-[var(--color-ink-500)] mb-8 leading-relaxed">
        歡迎透過 LINE 即時諮詢，或撥打服務專線，我們會根據您的需求推薦合適物件。
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href={SITE.lineAddFriendUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-7 py-3.5 text-white text-sm tracking-wider rounded-full transition-colors"
          style="background-color: #06C755"
        >
          LINE 即時諮詢
        </a>
        <a
          href={`tel:${SITE.phone}`}
          class="inline-flex items-center gap-2 px-7 py-3.5 border border-[var(--color-gold-300)] text-[var(--color-ink-700)] hover:bg-white text-sm tracking-wider rounded-full transition-colors"
        >
          撥打 {SITE.phone}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
