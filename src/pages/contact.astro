---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { SITE } from '~/lib/site';

const formspreeId = import.meta.env.PUBLIC_FORMSPREE_FORM_ID || 'YOUR_FORM_ID';
---

<BaseLayout
  title="聯絡我們"
  description="與鈺泰發行銷聯繫，預約看屋、購屋諮詢、合作洽談。"
  breadcrumbs={[
    { name: '首頁', href: '/' },
    { name: '聯絡我們', href: '/contact' },
  ]}
>
  <section class="pt-32 pb-12">
    <div class="container-custom">
      <p class="text-xs tracking-[0.4em] text-[var(--color-gold-500)] font-display mb-6">
        CONTACT
      </p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-light tracking-wide leading-tight text-[var(--color-ink-900)] mb-8">
        聯絡我們
      </h1>
      <p class="text-base text-[var(--color-ink-500)] max-w-2xl leading-relaxed">
        歡迎填寫表單與我們聯繫，或直接透過電話、LINE 與業務團隊溝通。我們會在工作日 24 小時內回覆。
      </p>
    </div>
  </section>

  <section class="pb-24 lg:pb-32">
    <div class="container-custom max-w-5xl">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
        <!-- 表單 -->
        <div class="lg:col-span-3">
          <form
            action={`https://formspree.io/f/${formspreeId}`}
            method="POST"
            class="space-y-6"
          >
            <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
            <input type="hidden" name="_subject" value="【鈺泰發官網】新客戶諮詢" />

            <div>
              <label class="block text-xs tracking-widest text-[var(--color-ink-700)] mb-2">
                姓名 <span class="text-[var(--color-gold-500)]">*</span>
              </label>
              <input
                type="text"
                name="name"
                required
                class="w-full px-4 py-3 bg-transparent border-b border-[var(--color-gold-300)]/60 focus:border-[var(--color-gold-500)] outline-none transition-colors text-[var(--color-ink-900)]"
              />
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label class="block text-xs tracking-widest text-[var(--color-ink-700)] mb-2">
                  電話 <span class="text-[var(--color-gold-500)]">*</span>
                </label>
                <input
                  type="tel"
                  name="phone"
                  required
                  class="w-full px-4 py-3 bg-transparent border-b border-[var(--color-gold-300)]/60 focus:border-[var(--color-gold-500)] outline-none transition-colors text-[var(--color-ink-900)]"
                />
              </div>
              <div>
                <label class="block text-xs tracking-widest text-[var(--color-ink-700)] mb-2">
                  Email
                </label>
                <input
                  type="email"
                  name="email"
                  class="w-full px-4 py-3 bg-transparent border-b border-[var(--color-gold-300)]/60 focus:border-[var(--color-gold-500)] outline-none transition-colors text-[var(--color-ink-900)]"
                />
              </div>
            </div>

            <div>
              <label class="block text-xs tracking-widest text-[var(--color-ink-700)] mb-2">
                諮詢類型
              </label>
              <select
                name="inquiry_type"
                class="w-full px-4 py-3 bg-transparent border-b border-[var(--color-gold-300)]/60 focus:border-[var(--color-gold-500)] outline-none transition-colors text-[var(--color-ink-900)]"
              >
                <option value="">請選擇</option>
                <option value="新成屋">新成屋代銷諮詢</option>
                <option value="中古屋">中古屋買賣諮詢</option>
                <option value="購屋諮詢">購屋一般諮詢</option>
                <option value="合作洽談">合作洽談</option>
                <option value="其他">其他</option>
              </select>
            </div>

            <div>
              <label class="block text-xs tracking-widest text-[var(--color-ink-700)] mb-2">
                地點偏好
              </label>
              <select
                name="location"
                class="w-full px-4 py-3 bg-transparent border-b border-[var(--color-gold-300)]/60 focus:border-[var(--color-gold-500)] outline-none transition-colors text-[var(--color-ink-900)]"
              >
                <option value="">請選擇</option>
                <option value="礁溪">礁溪</option>
                <option value="宜蘭市">宜蘭市</option>
                <option value="羅東">羅東</option>
                <option value="五結">五結</option>
                <option value="頭城">頭城</option>
                <option value="其他">其他（請於訊息註明）</option>
              </select>
            </div>

            <div>
              <label class="block text-xs tracking-widest text-[var(--color-ink-700)] mb-2">
                訊息 / 需求
              </label>
              <textarea
                name="message"
                rows="5"
                class="w-full px-4 py-3 bg-transparent border-b border-[var(--color-gold-300)]/60 focus:border-[var(--color-gold-500)] outline-none transition-colors text-[var(--color-ink-900)] resize-none"
              ></textarea>
            </div>

            <p class="text-xs text-[var(--color-ink-500)] leading-relaxed">
              送出表單即表示您同意我們依
              <a href="/privacy" class="text-[var(--color-gold-500)] underline">隱私權政策</a>
              處理您的個人資料，僅作為諮詢回覆與物件媒合用途。
            </p>

            <button
              type="submit"
              class="px-8 py-3.5 bg-[var(--color-gold-400)] hover:bg-[var(--color-gold-500)] text-white text-sm tracking-widest rounded-full transition-colors"
            >
              送出諮詢
            </button>
          </form>
        </div>

        <!-- 聯絡資訊 -->
        <aside class="lg:col-span-2 space-y-8">
          <div>
            <p class="text-xs tracking-[0.3em] text-[var(--color-gold-500)] font-display mb-3">
              CALL
            </p>
            <a
              href={`tel:${SITE.phone}`}
              class="text-2xl font-light text-[var(--color-ink-900)] hover:text-[var(--color-gold-500)] transition-colors tracking-wider"
            >
              {SITE.phone}
            </a>
          </div>

          <div>
            <p class="text-xs tracking-[0.3em] text-[var(--color-gold-500)] font-display mb-3">
              LINE
            </p>
            <a
              href={SITE.lineAddFriendUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-6 py-2.5 rounded-full text-white text-sm tracking-wider"
              style="background-color: #06C755"
            >
              加入 LINE 即時諮詢
            </a>
          </div>

          <div>
            <p class="text-xs tracking-[0.3em] text-[var(--color-gold-500)] font-display mb-3">
              EMAIL
            </p>
            <a
              href={`mailto:${SITE.email}`}
              class="text-base text-[var(--color-ink-900)] hover:text-[var(--color-gold-500)] transition-colors"
            >
              {SITE.email}
            </a>
          </div>

          <div>
            <p class="text-xs tracking-[0.3em] text-[var(--color-gold-500)] font-display mb-3">
              ADDRESS
            </p>
            <p class="text-base text-[var(--color-ink-900)] leading-relaxed">
              {SITE.address}
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- 地圖 -->
  <section class="pb-24">
    <div class="container-custom max-w-5xl">
      <p class="text-xs tracking-[0.3em] text-[var(--color-gold-500)] font-display mb-4">
        LOCATION
      </p>
      <h2 class="text-2xl md:text-3xl font-light tracking-wide text-[var(--color-ink-900)] mb-8">
        服務區域
      </h2>
      <div class="aspect-[16/9] overflow-hidden border border-[var(--color-gold-200)]/40">
        <iframe
          src="https://maps.google.com/maps?q=%E5%AE%9C%E8%98%AD%E7%B8%A3&t=&z=11&ie=UTF8&iwloc=&output=embed"
          class="w-full h-full"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="服務區域 - 宜蘭縣"
        ></iframe>
      </div>
      <p class="mt-4 text-xs text-[var(--color-ink-500)] tracking-wider">
        鈺泰發主要服務範圍涵蓋宜蘭縣全區，包含礁溪、宜蘭市、羅東、五結、頭城等地段。
      </p>
    </div>
  </section>
</BaseLayout>
