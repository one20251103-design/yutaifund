---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ArticleCard from '~/components/ArticleCard.astro';
import { getNewsList } from '~/lib/content';

const news = await getNewsList();
---

<BaseLayout
  title="最新消息"
  description="鈺泰發行銷的最新建案動態、活動公告與品牌訊息。"
  breadcrumbs={[
    { name: '首頁', href: '/' },
    { name: '最新消息', href: '/news' },
  ]}
>
  <section class="pt-32 pb-12">
    <div class="container-custom">
      <p class="text-xs tracking-[0.4em] text-[var(--color-gold-500)] font-display mb-6">
        NEWS
      </p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-light tracking-wide leading-tight text-[var(--color-ink-900)] mb-8">
        最新消息
      </h1>
      <p class="text-base text-[var(--color-ink-500)] max-w-2xl leading-relaxed">
        鈺泰發行銷的最新建案動態、活動公告與品牌訊息。
      </p>
    </div>
  </section>

  <section class="pb-24 lg:pb-32">
    <div class="container-custom">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        {news.map((item) => (
          <ArticleCard
            href={`/news/${item.slug}`}
            title={item.title}
            excerpt={item.excerpt}
            date={item.publishedAt}
            coverImage={item.coverImage}
            reveal="閱讀消息"
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
