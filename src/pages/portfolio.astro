---
import BaseLayout from '~/layouts/BaseLayout.astro';
import ProjectCard from '~/components/ProjectCard.astro';
import { getPortfolioList } from '~/lib/content';

const projects = await getPortfolioList();
---

<BaseLayout
  title="建案精選"
  description="鈺泰發行銷代銷與經手案例展示，包含新成屋與中古屋分類。"
  breadcrumbs={[
    { name: '首頁', href: '/' },
    { name: '建案精選', href: '/portfolio' },
  ]}
>
  <section class="pt-32 pb-12">
    <div class="container-custom">
      <p class="text-xs tracking-[0.4em] text-[var(--color-gold-500)] font-display mb-6">
        PORTFOLIO
      </p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-light tracking-wide leading-tight text-[var(--color-ink-900)] mb-8">
        建案精選
      </h1>
      <p class="text-base text-[var(--color-ink-500)] max-w-2xl leading-relaxed">
        以下為鈺泰發在不同地段、不同物件類型上的服務概念示範。實際案場資料正陸續從 CMS 串接，敬請期待。
      </p>
    </div>
  </section>

  <section class="pb-24 lg:pb-32">
    <div class="container-custom">
      <!-- Tabs（目前用錨點，全部資料一次顯示；未來接 Sanity 後改 client-side filter） -->
      <div class="flex gap-2 md:gap-4 border-b border-[var(--color-gold-200)]/40 mb-12">
        <a
          href="#all"
          class="px-5 py-3 text-sm tracking-widest text-[var(--color-ink-900)] border-b-2 border-[var(--color-gold-400)]"
        >
          全部
        </a>
        <a
          href="#new"
          class="px-5 py-3 text-sm tracking-widest text-[var(--color-ink-500)] hover:text-[var(--color-ink-900)] transition-colors"
        >
          新成屋建案
        </a>
        <a
          href="#used"
          class="px-5 py-3 text-sm tracking-widest text-[var(--color-ink-500)] hover:text-[var(--color-ink-900)] transition-colors"
        >
          中古屋
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="all">
        {projects.map((project) => (
          <ProjectCard project={project} />
        ))}
      </div>

      <p class="mt-16 text-xs text-[var(--color-ink-500)] text-center tracking-wider">
        以上為服務概念示範（Concept Study），非實際代銷案場。
      </p>
    </div>
  </section>
</BaseLayout>
