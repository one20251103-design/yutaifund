---
import BaseLayout from '~/layouts/BaseLayout.astro';
import NavIcon from '~/components/NavIcon.astro';
import { NAV_ITEMS } from '~/lib/site';

const portfolioNav = NAV_ITEMS.find((item) => item.href === '/portfolio');
const portfolioSubpages = portfolioNav?.children ?? [];

const SUBPAGE_ACCENTS: Record<string, { image: string; cta: string }> = {
  '/portfolio/upcoming': {
    image: 'https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?w=1200&q=80&auto=format&fit=crop',
    cta: '搶先掌握',
  },
  '/portfolio/hot': {
    image: 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=1200&q=80&auto=format&fit=crop',
    cta: '立即看屋',
  },
  '/portfolio/completed': {
    image: 'https://images.unsplash.com/photo-1554995207-c18c203602cb?w=1200&q=80&auto=format&fit=crop',
    cta: '回顧實績',
  },
};
---

<BaseLayout
  title="建案代銷"
  description="鈺泰發行銷代銷與經手案例展示，依銷售階段分為即將公開、熱銷中、已結案經典實績三大類。"
  breadcrumbs={[
    { name: '首頁', href: '/' },
    { name: '建案代銷', href: '/portfolio' },
  ]}
>
  <!-- Hero -->
  <section class="pt-32 pb-12">
    <div class="container-custom">
      <p class="text-xs tracking-[0.4em] text-[var(--color-gold-500)] font-display mb-6">
        PORTFOLIO
      </p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-light tracking-wide leading-tight text-[var(--color-ink-900)] mb-8">
        建案代銷
      </h1>
      <p class="text-base text-[var(--color-ink-500)] max-w-2xl leading-relaxed">
        鈺泰發行銷代銷的精選建案，依銷售階段分為三大類。請點選下方分類查看詳細物件資訊。
      </p>
    </div>
  </section>

  <!-- 3 個子頁卡片導覽 -->
  <section class="pb-24 lg:pb-32">
    <div class="container-custom">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {portfolioSubpages.map((page, i) => {
          const accent = SUBPAGE_ACCENTS[page.href] ?? SUBPAGE_ACCENTS['/portfolio/hot'];
          return (
            <a
              href={page.href}
              class="group block bg-white border border-[var(--color-gold-200)]/40 overflow-hidden hover:border-[var(--color-gold-400)] hover:shadow-md transition-all duration-300"
            >
              <div class="aspect-[4/3] overflow-hidden relative">
                <img
                  src={accent.image}
                  alt={page.label}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
                <div class="absolute top-4 left-4 px-3 py-1.5 bg-white/90 backdrop-blur-sm text-xs tracking-[0.2em] text-[var(--color-ink-900)]">
                  {String(i + 1).padStart(2, '0')}
                </div>
              </div>
              <div class="p-7">
                <div class="flex items-center gap-3 mb-3">
                  {page.icon && (
                    <span class="w-9 h-9 flex items-center justify-center rounded-md bg-[var(--color-cream-100)] group-hover:bg-[var(--color-gold-100)] text-[var(--color-gold-600)] transition-colors">
                      <NavIcon name={page.icon} class="w-5 h-5" />
                    </span>
                  )}
                  <h3 class="text-xl font-light text-[var(--color-ink-900)] tracking-wider group-hover:text-[var(--color-gold-600)] transition-colors">
                    {page.label}
                  </h3>
                </div>
                <p class="text-sm text-[var(--color-ink-500)] leading-relaxed mb-5">
                  {page.description}
                </p>
                <span class="inline-flex items-center gap-2 text-sm tracking-widest text-[var(--color-gold-600)] group-hover:text-[var(--color-gold-700)]">
                  {accent.cta}
                  <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
                </span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>
