---
import SubpageLayout from '~/layouts/SubpageLayout.astro';
import ProjectCard from '~/components/ProjectCard.astro';
import { getPortfolioList } from '~/lib/content';
import { SITE } from '~/lib/site';

const allProjects = await getPortfolioList();
// 熱銷暫用全部資料前 3 筆（待業主標記 status 後改為 filter）
const hotProjects = allProjects.slice(0, 3);
---

<SubpageLayout
  title="熱銷建案"
  description="目前正在銷售的精選建案，歡迎來電預約賞屋。"
  parentHref="/portfolio"
  eyebrow="NOW SELLING"
  breadcrumbs={[
    { name: '首頁', href: '/' },
    { name: '建案代銷', href: '/portfolio' },
    { name: '熱銷建案', href: '/portfolio/hot' },
  ]}
>
  <!-- 物件清單 -->
  <section class="py-16 lg:py-20">
    <div class="container-custom">
      <p class="text-xs tracking-[0.3em] text-[var(--color-gold-500)] font-display mb-4">
        HOT PROJECTS
      </p>
      <h2 class="text-2xl md:text-3xl font-light tracking-wide text-[var(--color-ink-900)] mb-12">
        熱銷中建案
      </h2>

      {hotProjects.length === 0 ? (
        <div class="border border-dashed border-[var(--color-gold-300)]/60 bg-[var(--color-cream-50)]/40 p-12 text-center">
          <p class="text-xs tracking-[0.3em] text-[var(--color-gold-500)] font-display mb-4">
            待業主提供
          </p>
          <p class="text-base text-[var(--color-ink-700)] leading-relaxed mb-2">
            熱銷建案資訊整備中
          </p>
          <p class="text-sm text-[var(--color-ink-500)]/80 leading-relaxed max-w-xl mx-auto">
            敬請鈺泰發提供：建案名稱、地段、總戶數、可售戶數、坪數、總價區間、銷售期、實景照片。
          </p>
        </div>
      ) : (
        <>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {hotProjects.map((project) => (
              <ProjectCard project={project} />
            ))}
          </div>
          <p class="mt-10 text-xs text-[var(--color-ink-500)]/70 tracking-wider">
            ※ 以上為服務概念示範（Concept Study），實際熱銷建案資料待業主標記後更新。
          </p>
        </>
      )}
    </div>
  </section>

  <!-- 賞屋提醒 -->
  <section class="py-16 lg:py-20 bg-[var(--color-cream-50)]">
    <div class="container-custom max-w-3xl">
      <p class="text-xs tracking-[0.3em] text-[var(--color-gold-500)] font-display mb-4">
        VIEWING TIPS
      </p>
      <h2 class="text-2xl md:text-3xl font-light tracking-wide text-[var(--color-ink-900)] mb-8">
        賞屋小提醒
      </h2>
      <ul class="space-y-4 text-sm text-[var(--color-ink-700)] leading-relaxed">
        <li class="flex gap-3">
          <span class="text-[var(--color-gold-500)] flex-shrink-0">·</span>
          <span><strong>不只看樣品屋</strong>：請務必到實際工地現場，了解真實建材與施工品質。</span>
        </li>
        <li class="flex gap-3">
          <span class="text-[var(--color-gold-500)] flex-shrink-0">·</span>
          <span><strong>注意周遭環境</strong>：早晚各看一次，了解交通、噪音、日照等不同時段的差異。</span>
        </li>
        <li class="flex gap-3">
          <span class="text-[var(--color-gold-500)] flex-shrink-0">·</span>
          <span><strong>確認規格細節</strong>：建材、坪數、車位、公設比逐項確認，避免簽約後爭議。</span>
        </li>
        <li class="flex gap-3">
          <span class="text-[var(--color-gold-500)] flex-shrink-0">·</span>
          <span><strong>合約逐條檢視</strong>：履約保證、違約條款、保固範圍是三大重點。</span>
        </li>
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 lg:py-20">
    <div class="container-custom max-w-3xl text-center">
      <h2 class="text-2xl md:text-3xl font-light tracking-wide text-[var(--color-ink-900)] mb-6">
        準備好預約賞屋了嗎？
      </h2>
      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href={SITE.lineAddFriendUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-7 py-3.5 text-white text-sm tracking-wider rounded-full transition-colors"
          style="background-color: #06C755"
        >
          LINE 預約賞屋
        </a>
        <a
          href={`tel:${SITE.phone}`}
          class="inline-flex items-center gap-2 px-7 py-3.5 border border-[var(--color-gold-300)] text-[var(--color-ink-700)] hover:bg-white text-sm tracking-wider rounded-full transition-colors"
        >
          撥打 {SITE.phone}
        </a>
      </div>
    </div>
  </section>
</SubpageLayout>
